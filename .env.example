# ── App ────────────────────────────────────────────────────────────

APP_NAME="Code Assistant Chatbot"
APP_VERSION="0.1"

PROVIDERS = "openai"

HF_Generation_MODEL_ID = ""
HF_Autocomplete_MODEL_ID = ""
HF_Audit_MODEL_ID = ""

# ── OpenAI / GitHub Models inference ───────────────────────────────

# Used for: LLM calls, embeddings (text-embedding-3-small)
OPENAI_API_KEY="your_api_key_here"
OPENAI_API_URL="your_api_url_here"
OPENAI_MODEL_ID = "your_model_here"


# ── Vector Store ───────────────────────────────────────────────────

# Directory where ChromaDB persists all collections

# (project DBs + shared codebase DB)

CHROMA_PERSIST_DIR="assets/vector_store"

# ── Project Files ──────────────────────────────────────────────────

# Root directory for uploaded project archives and extracted files

PROJECTS_BASE_DIR="assets/projects"

# ── Codebase RAG ───────────────────────────────────────────────────

# Directory where curated GitHub repos are cloned

CODEBASE_REPOS_DIR="assets/codebase/repos"

# ── Output Files ───────────────────────────────────────────────────

# Directory where generated/refined code files are written

OUTPUT_BASE_DIR="assets/output"
